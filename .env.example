# Set to "true" in dev to point the web app at local Firebase emulators
VITE_USE_EMULATORS=true

# Firebase Web SDK config (public, safe to expose)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Kakao Maps JS SDK key (public, protected by domain allowlist in Kakao console)
VITE_KAKAO_MAP_KEY=

# NEVER put TourAPI / Admin key / REST key here.
# They must live in Cloud Functions runtime config only.
