rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Public read-only reference data (prices, rules, mappings)
    // Writes only via Cloud Functions / admin SDK
    match /prices/{doc=**} {
      allow read: if true;
      allow write: if false;
    }
    match /rules/{doc=**} {
      allow read: if true;
      allow write: if false;
    }
    match /mappings/{doc=**} {
      allow read: if true;
      allow write: if false;
    }

    // 공공 API 기반 실시간 가격 캐시 (한국은행 환율 등). Cloud Function만 쓰기.
    match /livePrices/{doc=**} {
      allow read: if true;
      allow write: if false;
    }

    // Curated course documents (Bucheon specialization).
    // Public can read only documents marked published=true.
    // Writes are restricted to users with the admin custom claim,
    // so a future admin CMS can edit courses directly from the client.
    match /courses/{courseId} {
      allow read: if resource.data.published == true;
      allow create, update, delete: if request.auth != null
        && request.auth.token.admin == true;

      // Per-course heart (like). Doc id is the liker's uid. Existence
      // alone represents the like; no fields are trusted from the client.
      match /likes/{uid} {
        allow read: if true;
        allow create: if request.auth != null
          && request.auth.uid == uid;
        allow delete: if request.auth != null
          && request.auth.uid == uid;
      }

      // Per-course user notes (comments). Read is open — clients hide
      // moderated rows by checking the `hidden` flag locally, which
      // keeps the query simple (no composite index needed and no
      // "insecure query" errors from the Firestore rules engine). Admin
      // moderation still prevents further edits from surfacing content.
      match /notes/{noteId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.uid
          && request.resource.data.hidden == false
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0;
        allow update: if request.auth != null && request.auth.token.admin == true;
        allow delete: if request.auth != null
          && (request.auth.token.admin == true
            || request.auth.uid == resource.data.uid);
      }
    }

    // Public price-check log: anyone can read recent entries for the
    // home hero feed. Authenticated users may publish a masked result
    // (no uid, only first-char-of-email + domain). Admins can hide or
    // delete rows for moderation. Read is open and clients filter out
    // hidden==true rows locally, matching the existing notes pattern.
    match /publicChecks/{docId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(
          ['entryId','category','paid','fairMin','fairMax','verdict','extra','emailMasked','hidden','createdAt']
        )
        && request.resource.data.hidden == false
        && request.resource.data.verdict in ['fair','careful','bagaji']
        && request.resource.data.category in ['food','drink','transit','lodging','tourism','fee']
        && request.resource.data.entryId is string
        && request.resource.data.entryId.size() > 0
        && request.resource.data.entryId.size() < 64
        && request.resource.data.paid is number
        && request.resource.data.paid >= 0
        && request.resource.data.fairMin is number
        && request.resource.data.fairMax is number
        && request.resource.data.emailMasked is string
        && request.resource.data.emailMasked.size() < 120;
      allow update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // User-owned data: only the authenticated owner can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{sub=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
