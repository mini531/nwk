rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Public read-only reference data (prices, rules, mappings)
    // Writes only via Cloud Functions / admin SDK
    match /prices/{doc=**} {
      allow read: if true;
      allow write: if false;
    }
    match /rules/{doc=**} {
      allow read: if true;
      allow write: if false;
    }
    match /mappings/{doc=**} {
      allow read: if true;
      allow write: if false;
    }

    // User-owned data: only the authenticated owner can read/write
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{sub=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
